# Python
.venv/
__pycache__/
*.py[cod]
.Python
*.egg-info/
dist/
build/

# 运行时记忆数据（保留目录结构）
data/photos/*
!data/photos/.gitkeep
data/memory/*
!data/memory/.gitkeep
data/.geocode_cache.json
data/cache/**
data/*.db

# 人脸库（参考照与索引不进 git）
data/faces/**/*
!data/faces/README.md
!data/faces/registry.example.json
!data/faces/baby/.gitkeep
data/faces/index.json
data/faces/registry.json

