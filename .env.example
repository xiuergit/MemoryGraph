# 高德 Web 服务 API Key（逆地理编码：坐标 → 中文地址）
# 申请：https://lbs.amap.com/ → 控制台 → 应用管理 → 创建 Key（Web 服务）
AMAP_KEY=3614ed14a5b3e0942bca7a96ab762ffa

# Ollama 本地视觉模型（场景 / 物体 / 动作 / tags 等）
# 回家后在终端执行 ollama list 查看已安装模型名，改下面这一行即可
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_VISION_MODEL=qwen2.5vl:7b
OLLAMA_VISION_ENABLED=true
OLLAMA_TIMEOUT=180

# Agent 问答用的文本模型（ollama list 里任选一个 chat 模型）
OLLAMA_CHAT_MODEL=qwen2.5:7b
OLLAMA_CHAT_ENABLED=true

# 人脸识别匹配阈值（0~1，越高越严格）
FACE_MATCH_THRESHOLD=0.45

# InsightFace 模型（buffalo_s 小且下载快；要更准可改 buffalo_l）
INSIGHTFACE_MODEL=buffalo_s
# INSIGHTFACE_ROOT=/Users/you/.insightface/models

# CLIP 衣着兜底（脸不清时比对当天穿搭）
CLIP_ENABLED=true
CLIP_MODEL_NAME=ViT-B-32
CLIP_PRETRAINED=openai
# 国内首次下载 CLIP 慢/超时时：
# HF_ENDPOINT=https://hf-mirror.com   （项目 config 已默认此镜像）
# 或手动下载：bash tools/download_clip.sh，再设 CLIP_PRETRAINED=.../open_clip_model.safetensors
# 暂时跳过：CLIP_ENABLED=false
OUTFIT_MATCH_THRESHOLD=0.82
OUTFIT_MAX_CONFIDENCE=0.72
