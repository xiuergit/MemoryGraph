# 高德 Web 服务 API Key（逆地理编码：坐标 → 中文地址）
# 申请：https://lbs.amap.com/ → 控制台 → 应用管理 → 创建 Key（Web 服务）
AMAP_KEY=你的高德Key

# Ollama 本地视觉模型（场景 / 物体 / 动作 / tags 等）
# 回家后在终端执行 ollama list 查看已安装模型名，改下面这一行即可
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_VISION_MODEL=qwen2.5vl:7b
OLLAMA_VISION_ENABLED=true
OLLAMA_TIMEOUT=180

# 人脸识别匹配阈值（0~1，越高越严格）
FACE_MATCH_THRESHOLD=0.45

# InsightFace 模型（buffalo_s 小且下载快；要更准可改 buffalo_l）
INSIGHTFACE_MODEL=buffalo_s
# INSIGHTFACE_ROOT=/Users/you/.insightface/models
